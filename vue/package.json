{
  "name": "@mashkoffdmitry/pelican-vue",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Vue 3 component for browsing Libertex Social copy-trading strategies via a pelican-libertex-social proxy.",
  "sideEffects": ["**/*.css"],
  "main": "./dist/pelican-libertex-social.umd.cjs",
  "module": "./dist/pelican-libertex-social.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pelican-libertex-social.mjs",
      "require": "./dist/pelican-libertex-social.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mashkoffdmitry/pelican-libertex-social.git",
    "directory": "vue"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
