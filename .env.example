# Pelican Libertex Social — environment template.
# Copy to .env, fill in your own values.
# .env is in .gitignore — never commit your real credentials.

# ---- Libertex Social account (required) ----
# Used by oidc-client.js to perform PKCE login against identity.copy-trade.io.
LIBERTEX_EMAIL=your-email@example.com
LIBERTEX_PASSWORD=your-password-here

# ---- Container / cluster only ----
# Random secret protecting POST /__ingest from external callers (emergency
# manual token push). Localhost POSTs are allowed unconditionally.
# Generate: openssl rand -hex 32
INGEST_SECRET=

# Where refresher.js writes the rotating .env (must be a writable path).
# In the Docker image this defaults to /tmp/.env (tmpfs); for self-hosted
# Node runs, leave empty to fall back to <repo>/.env.
ENV_PATH=

# ---- Cloudflare Worker catalog ingest (optional) ----
# When set, server.js POSTs the freshly-built full catalog to the Worker after
# every rebuild. The Worker writes it to R2 and serves it on the edge. Leave
# empty to disable — proxy keeps serving /api/strategies-full directly.
# CATALOG_INGEST_URL=https://pelican-catalog-worker.<account>.workers.dev/__ingest
# CATALOG_INGEST_SECRET=<same as Worker INGEST_SECRET binding>
# CATALOG_REBUILD_INTERVAL_H=6   # how often to rebuild the full catalog (default: 6)

# ---- Optional: IdP overrides (defaults work for production Libertex) ----
# LIBERTEX_AUTHORITY=https://identity.copy-trade.io
# LIBERTEX_CLIENT_ID=libertexweb
# LIBERTEX_TENANT=Libertex
# LIBERTEX_SCOPE="openid profile email copytrade offline_access"
# LIBERTEX_REDIRECT_URI=https://libertex.copy-trade.io/authentication/login-callback

# ---- Runtime (do not edit; refresher.js writes here) ----
# ACCESS_TOKEN=
# REFRESH_TOKEN=
# EXPIRES_AT=
# SAVED_AT=
